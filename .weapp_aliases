alias devops-pr-my='az repos pr list --creator "$(az ad signed-in-user show --query userPrincipalName -o tsv)" --status active --output table'
# List all pull requests (active)
alias devops-pr-list='az repos pr list --status active --output table'
# Get PR diff / changed files (usage: devops-pr-diff <PR_ID>)
alias devops-pr-diff='function _devops_pr_diff(){ az repos pr files list --id "$1" --output table; }; _devops_pr_diff'
# Get PR comments (usage: devops-pr-comments <PR_ID>)
alias devops-pr-comments='function _devops_pr_comments(){ az repos pr reviewer list --id "$1" --output table; }; _devops_pr_comments'
# Get PR details (usage: devops-pr-show <PR_ID>)
alias devops-pr-show='function _devops_pr_show(){ az repos pr show --id "$1" --output table; }; _devops_pr_show'
# List repositories
alias devops-repos='az repos list --output table'
# List pipelines
alias devops-pipelines='az pipelines list --output table'
# Run a pipeline by name (usage: devops-pipeline-run "<PIPELINE_NAME>")
alias devops-pipeline-run='function _devops_pipeline_run(){ az pipelines run --name "$1" --output table; }; _devops_pipeline_run'
alias devops-config='az devops configure --list --output table'
alias devops-me='az ad signed-in-user show --output table'



