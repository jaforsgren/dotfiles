alias ls-cert='aws acm list-certificates --region eu-north-1 --profile boxprod'
alias ls-rec='listrec'
alias ls-zones='aws route53 list-hosted-zones --query "HostedZones[*].[Id,Name]" --output table'
alias ls-users='aws cognito-idp list-users \
  --user-pool-id eu-north-1_JoUGsySO \
  --query "Users[?UserCreateDate>=\`$(date -u -v-7d +%Y-%m-%dT%H:%M:%SZ)\`].[Username, UserCreateDate, Attributes[?Name==\`email\`].Value | [0]]" \
  --output table \
  --profile boxprod'


alias ls-env='f() { \
    PROFILE_ARG=""; \
    if [ -n "$2" ]; then PROFILE_ARG="--profile $2"; fi; \
    TASK_DEF=$(aws ecs describe-services \
        --cluster BoxtimeCluster \
        --services "$1" \
        --region eu-north-1 $PROFILE_ARG \
        --query "services[0].taskDefinition" \
        --output text); \
    aws ecs describe-task-definition \
        --task-definition "$TASK_DEF" \
        --region eu-north-1 $PROFILE_ARG \
        --query "taskDefinition.containerDefinitions[0].environment" \
        --output table; \
}; f'


alias dockerlogin='aws ecr get-login-password --region eu-north-1 \
  | docker login --username AWS --password-stdin \
  $(aws sts get-caller-identity --query Account --output text).dkr.ecr.eu-north-1.amazonaws.com'

alias dockerloginprod='aws ecr get-login-password --region eu-north-1 --profile boxprod \
  | docker login --username AWS --password-stdin \
  $(aws sts get-caller-identity --query Account --output text --profile boxprod).dkr.ecr.eu-north-1.amazonaws.com'

